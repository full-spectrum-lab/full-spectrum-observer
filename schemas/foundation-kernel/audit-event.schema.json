{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fullspectrumprotocol.com/schemas/observer/foundation-kernel/audit-event/1.0.0-alpha.1",
  "x-fsp-status": "APPROVED_DESIGN_BASELINE",
  "x-fsp-schema-set": "FS-OBS-V010-SCHEMA-BL-1.0",
  "x-fsp-common-fragment-policy": "SELF_CONTAINED_GENERATED_FS_OBS_COMMON_1",
  "title": "AuditEvent",
  "type": "object",
  "required": [
    "contract",
    "event_id",
    "stream_id",
    "sequence_no",
    "event_type",
    "occurred_at_utc",
    "actor",
    "trace_id",
    "payload_digest",
    "payload_media_type",
    "serialization_id",
    "previous_hash",
    "event_hash"
  ],
  "properties": {
    "contract": {
      "const": "fs-observer/audit-event/1"
    },
    "event_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "stream_id": {
      "const": "GLOBAL"
    },
    "sequence_no": {
      "type": "integer",
      "minimum": 1
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "SYSTEM",
            "OPERATOR",
            "SERVICE"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "observation_id": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "operation_id": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "trace_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "payload_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "payload_media_type": {
      "type": "string",
      "minLength": 1
    },
    "serialization_id": {
      "const": "FS-OBS-CANON-1"
    },
    "previous_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "event_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "SHA-256(FS-OBS-CANON-1(AuditEvent with event_hash property removed; previous_hash retained))",
      "x-fsp-digest-rule": "SHA-256(FS-OBS-CANON-1(AuditEvent with event_hash property removed; previous_hash retained))",
      "x-fsp-excluded-fields": [
        "event_hash"
      ]
    }
  },
  "additionalProperties": false
}
