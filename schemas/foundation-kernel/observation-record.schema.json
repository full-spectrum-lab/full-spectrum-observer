{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fullspectrumprotocol.com/schemas/observer/foundation-kernel/observation-record/1.0.0-alpha.1",
  "x-fsp-status": "APPROVED_DESIGN_BASELINE",
  "x-fsp-schema-set": "FS-OBS-V010-SCHEMA-BL-1.0",
  "x-fsp-common-fragment-policy": "SELF_CONTAINED_GENERATED_FS_OBS_COMMON_1",
  "title": "ObservationRecord",
  "type": "object",
  "required": [
    "contract",
    "observation_id",
    "operation_id",
    "request_id",
    "trace_id",
    "status",
    "input_sha256",
    "runtime_snapshot_id",
    "output_ref",
    "audit_head",
    "created_at_utc",
    "updated_at_utc"
  ],
  "properties": {
    "contract": {
      "const": "fs-observer/observation-record/1"
    },
    "observation_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "operation_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "request_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "COMPLETED",
        "REJECTED_SCHEMA",
        "NEEDS_EVIDENCE",
        "ADAPTER_FAILED",
        "ENGINE_FAILED",
        "STORE_FAILED",
        "CANCELLED",
        "TIMED_OUT",
        "INTERNAL_FAILED"
      ]
    },
    "input_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "canonical_context_sha256": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "runtime_snapshot_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "output_ref": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "artifact_id",
            "media_type",
            "sha256",
            "size_bytes"
          ],
          "properties": {
            "artifact_id": {
              "type": "string",
              "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
            },
            "media_type": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "size_bytes": {
              "type": "integer",
              "minimum": 0
            },
            "relative_path": {
              "type": "string",
              "minLength": 1
            },
            "classification": {
              "type": "string",
              "enum": [
                "SYNTHETIC",
                "PUBLIC",
                "INTERNAL",
                "CONFIDENTIAL",
                "RESTRICTED"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    },
    "audit_head": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "created_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "updated_at_utc": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
