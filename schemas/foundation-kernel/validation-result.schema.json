{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fullspectrumprotocol.com/schemas/observer/foundation-kernel/validation-result/1.0.0-alpha.1",
  "x-fsp-status": "APPROVED_DESIGN_BASELINE",
  "x-fsp-schema-set": "FS-OBS-V010-SCHEMA-BL-1.0",
  "x-fsp-common-fragment-policy": "SELF_CONTAINED_GENERATED_FS_OBS_COMMON_1",
  "title": "ValidationResult",
  "type": "object",
  "required": [
    "contract",
    "validation_kind",
    "status",
    "reason_codes",
    "validated_at_utc"
  ],
  "properties": {
    "contract": {
      "const": "fs-observer/validation-result/1"
    },
    "validation_kind": {
      "type": "string",
      "enum": [
        "SCHEMA",
        "GOVERNANCE"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL",
        "NEEDS_EVIDENCE",
        "BLOCKED"
      ]
    },
    "schema_ref": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "id",
            "version",
            "sha256"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,63}$"
            },
            "schema_version": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,63}$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "source_commit": {
              "type": "string",
              "pattern": "^[0-9a-f]{40}$"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^(REQ|INTAKE|ADAPTER|SCHEMA|GOV|SNAPSHOT|FACADE|ENGINE|OUTPUT|STORE|AUDIT|SEC|SYSTEM)_[A-Z0-9_]+$"
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "field_path": {
            "type": "string"
          },
          "retryable": {
            "type": "boolean"
          },
          "details_redacted": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "known_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unknown_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validated_at_utc": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
